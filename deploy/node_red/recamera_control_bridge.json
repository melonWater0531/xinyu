  {
    "id": "rc-session-start",
    "type": "function",
    "z": "rc-tab",
    "name": "Authorize session",
    "func": "const p=msg.payload||{}; const sid=String(p.session_id||''); const lease=Math.max(500,Math.min(2000,Number(p.lease_ms||750))); if(!sid){msg.statusCode=400;msg.payload={ok:false,accepted:false,error:'session_id_required'};return msg;} flow.set('rcSession',sid);flow.set('rcLeaseDeadline',Date.now()+lease);flow.set('rcLastSequence',0);msg.statusCode=200;msg.payload={ok:true,accepted:true,session_id:sid,lease_ms:lease};return msg;",
    "outputs": 1,
    "x": 360,
    "y": 540,
    "wires": [
      [
        "rc-http-session-response"
      ]
    ]
  },
