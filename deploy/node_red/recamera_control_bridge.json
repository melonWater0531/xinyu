  {
    "id": "rc-validate-command",
    "type": "function",
    "z": "rc-tab",
    "name": "Validate and route",
    "func": "const p = msg.payload || {};\nconst now = Date.now();\nconst sid = String(p.session_id || '');\nconst active = String(flow.get('rcSession') || '');\nconst deadline = Number(flow.get('rcLeaseDeadline') || 0);\nconst seq = Number(p.sequence || 0);\nconst lastSeq = Number(flow.get('rcLastSequence') || 0);\nif (!sid || sid !== active || now >= deadline) {\n  msg.statusCode=409; msg.payload={ok:false,accepted:false,error:'control_lease_invalid'}; return [null,null,msg];\n}\nif (!Number.isFinite(seq) || seq <= lastSeq || Number(p.expires_at || 0) * 1000 <= now) {\n  msg.statusCode=409; msg.payload={ok:false,accepted:false,error:'stale_command'}; return [null,null,msg];\n}\nconst mode = p.mode === 'delta' ? 'delta' : 'absolute';\nconst yaw = p.yaw === null || p.yaw === undefined ? (mode === 'delta' ? 0 : flow.get('rcYaw')) : Number(p.yaw);\nconst pitch = p.pitch === null || p.pitch === undefined ? (mode === 'delta' ? 0 : flow.get('rcPitch')) : Number(p.pitch);\nconst ys = Math.max(1, Math.min(720, Number(p.yaw_speed || 180)));\nconst ps = Math.max(1, Math.min(720, Number(p.pitch_speed || 180)));\nif (!Number.isFinite(yaw) || !Number.isFinite(pitch)) {\n  msg.statusCode=400; msg.payload={ok:false,accepted:false,error:'invalid_angles'}; return [null,null,msg];\n}\nflow.set('rcLastSequence', seq);\nconst motor = RED.util.cloneMessage(msg);\nmotor.payload={yaw_angle:yaw,yaw_speed:ys,pitch_angle:pitch,pitch_speed:ps};\nconst response = RED.util.cloneMessage(msg);\nresponse.statusCode=202; response.payload={ok:true,accepted:true,mode,sequence:seq};\nreturn mode === 'delta' ? [null,motor,response] : [motor,null,response];",
    "outputs": 3,
    "timeout": 0,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 530,
    "y": 80,
    "wires": [
      [
        "rc-set-absolute"
      ],
      [
        "rc-set-delta"
      ],
      [
        "rc-http-command-response"
      ]
    ]
  },
